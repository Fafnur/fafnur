{
  "name": "fafnur",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/fafnur/src",
  "tags": [],
  "i18n": {
    "sourceLocale": "en-US",
    "locales": {
      "ru": {
        "translation": "apps/fafnur/i18n/messages.ru.xlf",
        "subPath": ""
      }
    }
  },
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/fafnur",
        "browser": "apps/fafnur/src/main.ts",
        "tsConfig": "apps/fafnur/tsconfig.app.json",
        "polyfills": ["@angular/localize/init", "core-js/stable"],
        "localize": ["ru"],
        "inlineStyleLanguage": "scss",
        "stylePreprocessorOptions": {
          "includePaths": ["node_modules", "./"]
        },
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/fafnur/public"
          }
        ],
        "externalDependencies": ["assets/*"],
        "styles": [],
        "server": "apps/fafnur/src/main.server.ts",
        "ssr": {
          "entry": "apps/fafnur/src/server.ts"
        },
        "outputMode": "static"
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "fafnur:build:production"
        },
        "development": {
          "buildTarget": "fafnur:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "fafnur:build",
        "port": 4200,
        "staticFilePath": "dist/apps/fafnur/browser",
        "spa": true,
        "brotli": true,
        "cacheSeconds": 2593000,
        "sslKey": "ssl/localhost-key.pem",
        "sslCert": "ssl/localhost-cert.pem"
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "../../coverage/apps/fafnur"
      }
    },
    "extract-i18n": {
      "executor": "@angular/build:extract-i18n",
      "options": {
        "buildTarget": "fafnur:build"
      }
    }
  }
}
